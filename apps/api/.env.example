# ─── Server ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── CORS / origins permitidos (coma-separados) ─────
CORS_ORIGINS=http://localhost:3000,http://app.localhost:3000,https://trescerbero.com,https://app.trescerbero.com

# ─── MySQL (Hostinger nativo en prod) ────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tr3sc3rb3r0_dev
DB_CONNECTION_LIMIT=10

# ─── Sesiones ───────────────────────────────────────
# Cookie name + TTL en segundos (30 días por defecto)
SESSION_COOKIE_NAME=tc_session
SESSION_TTL_SECONDS=2592000
# Si true, cookie sólo viaja por HTTPS (activar en prod)
SESSION_COOKIE_SECURE=false
# Domain para que la cookie funcione entre trescerbero.com y app.trescerbero.com
SESSION_COOKIE_DOMAIN=

# ─── Hash de passwords (Argon2id) ───────────────────
ARGON_MEMORY_KIB=19456
ARGON_ITERATIONS=2
ARGON_PARALLELISM=1

# ─── n8n (HMAC bidireccional, llega en módulos siguientes) ─
N8N_BASE_URL=https://n8n.donweb-tudominio.com
N8N_HMAC_SECRET=cambiar-en-prod-32+chars-random
N8N_WEBHOOK_AUTH_EMAILS=/webhook/auth-emails

# ─── IA (Fase 1 Anthropic/Groq, llega en módulos siguientes) ─
ANTHROPIC_API_KEY=
GROQ_API_KEY=
