{
  "name": "@tr3sc3rb3r0/web",
  "version": "1.0.0",
  "description": "Frontend público — landing, planes, bundles, legales. Vanilla HTML/CSS/JS hoy; migra a Astro cuando se justifique.",
  "private": true,
  "type": "module",
  "main": "server/index.js",
  "engines": { "node": ">=20" },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon --watch server --watch public server/index.js",
    "optimize:svg": "svgo -f public/assets/heads -o public/assets/heads --multipass",
    "optimize:raster": "node scripts/optimize-svg-raster.cjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "svgo": "^3.3.2"
  }
}
